<div class="workspace-section" id="workspace-section-skillcheckrolls-{{id}}">
    <h4>Roll Details <button type="button" class="toggle-button-section" onclick="toggleSection('workspace-section-skillcheckrolls-content-{{id}}', this)"><i class="fas fa-chevron-up"></i></button></h4>
    <div id="workspace-section-skillcheckrolls-content-{{id}}" class="workspace-section-content">

        <div class="regent-roll-details-row">
            <select id="optionSkill-{{id}}" class="regent-roll-details-skill">
                <option value="Acrobatics">Acrobatics</option>
                <option value="Animal Handling">Animal Handling</option>
                <option value="Arcana">Arcana</option>
                <option value="Athletics">Athletics</option>
                <option value="Deception">Deception</option>
                <option value="History">History</option>
                <option value="Insight">Insight</option>
                <option value="Intimidation">Intimidation</option>
                <option value="Investigation" selected>Investigation</option>
                <option value="Medicine">Medicine</option>
                <option value="Nature">Nature</option>
                <option value="Perception">Perception</option>
                <option value="Performance">Performance</option>
                <option value="Persuasion">Persuasion</option>
                <option value="Religion">Religion</option>
                <option value="Sleight of Hand">Sleight of Hand</option>
                <option value="Stealth">Stealth</option>
                <option value="Survival">Survival</option>
            </select>
            <input type="text" id="inputDiceValue-{{id}}" class="regent-roll-details-result" placeholder="Result" size="2" maxlength="2" value="" title="Filled when you use Request Roll (two digits)">
            <button type="button" id="rollDiceButton-{{id}}" class="roll-dice-button regent-roll-details-d20" title="Request roll (Blacksmith Request a Roll)">
                <i class="fas fa-dice-d20"></i>
            </button>
        </div>
        <label class="regent-roll-details-checkbox">
            <input type="checkbox" id="blnSkillRoll-{{id}}" checked> Use <b>Skill Check</b> results to scale the narrative
        </label>

    </div>
</div>