{{!--
  Regent Application V2 shell — zone contract (option bar, header, tools, body, action bar).
  Class names: blacksmith-window-template-* (shared naming for Regent styles).
  Data: appId, showOptionBar, showHeader, showTools, showActionBar,
  optionBarLeft/Right, headerIcon, windowTitle, subtitle, headerRight,
  toolsContent, bodyContent, actionBarLeft, actionBarRight.
--}}

<div class="blacksmith-window-template-root" id="{{appId}}">

    {{#if showOptionBar}}
    <div class="blacksmith-window-template-option-bar">
        <div class="blacksmith-window-template-option-bar-left">
            {{#if optionBarLeft}}{{{optionBarLeft}}}{{/if}}
        </div>
        <div class="blacksmith-window-template-option-bar-right">
            {{#if optionBarRight}}{{{optionBarRight}}}{{/if}}
        </div>
    </div>
    {{/if}}

    {{#if showHeader}}
    <header class="blacksmith-window-template-header">
        <div class="blacksmith-window-template-header-content">
            <div class="blacksmith-window-template-header-icon">
                {{#if headerIcon}}<i class="{{headerIcon}}"></i>{{else}}<i class="fa-solid fa-crystal-ball"></i>{{/if}}
            </div>
            <div class="blacksmith-window-template-header-title-block">
                <div class="blacksmith-window-template-header-title">{{windowTitle}}</div>
                <div class="blacksmith-window-template-header-subtitle">{{subtitle}}</div>
            </div>
            <div class="blacksmith-window-template-header-right">
                {{#if headerRight}}{{{headerRight}}}{{/if}}
            </div>
        </div>
    </header>
    {{/if}}

    {{#if showTools}}
    <div class="blacksmith-window-template-tools">
        {{#if toolsContent}}{{{toolsContent}}}{{/if}}
    </div>
    {{/if}}

    <div class="blacksmith-window-template-body">
        {{#if bodyContent}}{{{bodyContent}}}{{/if}}
    </div>

    {{#if showActionBar}}
    <section class="blacksmith-window-template-buttons">
        <div class="blacksmith-window-template-action-bar">
            <div class="blacksmith-window-template-action-left">
                {{#if actionBarLeft}}{{{actionBarLeft}}}{{/if}}
            </div>
            <div class="blacksmith-window-template-action-right">
                {{#if actionBarRight}}{{{actionBarRight}}}{{/if}}
            </div>
        </div>
    </section>
    {{/if}}
</div>
